{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["templates/**", "static/**", "knowledge_base/**", "models/**", "services/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "DB_PATH": "/tmp/tickets.db"
  },
  "functions": {
    "app.py": {
      "maxDuration": 30
    }
  }
}
